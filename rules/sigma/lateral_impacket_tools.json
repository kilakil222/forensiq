{
  "title": "Impacket Lateral Movement Toolset",
  "id": "d4e5f6a7-b8c9-0123-def0-234567890123",
  "status": "stable",
  "description": "Detects Impacket tools commonly used for lateral movement: wmiexec, smbexec, psexec.py, secretsdump, atexec. These produce distinctive process names and command line patterns.",
  "level": "high",
  "tags": ["attack.lateral_movement", "attack.credential_access", "attack.t1021.002", "attack.t1047"],
  "logsource": {"category": "process_creation", "product": "windows"},
  "detection": {
    "selection_names": {
      "Image|endswith": [
        "\\wmiexec.exe",
        "\\smbexec.exe",
        "\\atexec.exe",
        "\\secretsdump.exe"
      ]
    },
    "selection_cmdline": {
      "CommandLine|contains": [
        "wmiexec",
        "smbexec",
        "secretsdump",
        "impacket",
        "ADMIN$\\Temp",
        "cmd.exe /Q /c",
        "__MSDTC_SHUTDOWN__"
      ]
    },
    "selection_service": {
      "Image|endswith": ["\\cmd.exe"],
      "CommandLine|contains": [
        "PSEXESVC",
        "RemCom",
        "PAExec"
      ]
    },
    "condition": "selection_names or selection_cmdline or selection_service"
  }
}
