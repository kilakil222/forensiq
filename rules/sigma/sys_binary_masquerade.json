{
  "title": "System Binary Running from Non-Standard Path",
  "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
  "status": "stable",
  "description": "Detects Windows system binaries (svchost, lsass, notepad, cmd, explorer) running from directories other than System32/SysWOW64 — a masquerading technique to evade detection.",
  "level": "high",
  "tags": ["attack.defense_evasion", "attack.t1036.003"],
  "logsource": {"category": "process_creation", "product": "windows"},
  "detection": {
    "selection": {
      "Image|endswith": [
        "\\svchost.exe", "\\lsass.exe", "\\services.exe",
        "\\smss.exe", "\\csrss.exe", "\\wininit.exe",
        "\\notepad.exe", "\\explorer.exe"
      ]
    },
    "filter_legit": {
      "Image|contains": [
        "\\Windows\\System32\\",
        "\\Windows\\SysWOW64\\",
        "\\Windows\\WinSxS\\"
      ]
    },
    "condition": "selection and not filter_legit"
  },
  "falsepositives": ["Custom system tools in non-standard paths", "Some security software"]
}
