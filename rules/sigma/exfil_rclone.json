{
  "title": "Data Exfiltration Tool: rclone",
  "id": "b5c6d7e8-f9a0-4b1c-d2e3-f4a5b6c7d8e9",
  "status": "stable",
  "description": "Detects rclone being used to sync or copy data to cloud storage — common data exfiltration tool used by ransomware groups.",
  "level": "high",
  "tags": ["attack.exfiltration", "attack.t1048", "attack.t1567.002"],
  "logsource": {"category": "process_creation", "product": "windows"},
  "detection": {
    "selection_name": {
      "Image|endswith": ["\\rclone.exe"]
    },
    "selection_cmd": {
      "CommandLine|contains": ["rclone"]
    },
    "selection_operation": {
      "CommandLine|contains": ["copy", "sync", "move", "mount"]
    },
    "condition": "selection_name or (selection_cmd and selection_operation)"
  },
  "falsepositives": ["Authorized cloud backup solutions using rclone", "IT backup workflows"]
}
