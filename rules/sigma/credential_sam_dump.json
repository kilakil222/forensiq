{
  "title": "SAM Database Dump via Registry Save",
  "id": "f3a4b5c6-d7e8-4f9a-b0c1-d2e3f4a5b6c7",
  "status": "stable",
  "description": "Detects reg.exe saving SAM, SYSTEM, or SECURITY hives — used to dump credentials offline.",
  "level": "critical",
  "tags": ["attack.credential_access", "attack.t1003.002"],
  "logsource": {"category": "process_creation", "product": "windows"},
  "detection": {
    "selection_reg": {
      "Image|endswith": ["\\reg.exe"],
      "CommandLine|contains|all": ["save", "HKLM\\"]
    },
    "selection_hive": {
      "CommandLine|contains": ["\\SAM", "\\SECURITY", "\\SYSTEM", "\\sam", "\\security", "\\system"]
    },
    "condition": "selection_reg and selection_hive"
  },
  "falsepositives": ["Backup scripts that save registry hives", "System backup tools"]
}
