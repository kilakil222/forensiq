{
  "title": "PowerShell Encoded Command Execution",
  "id": "e4e86cfb-b19d-4b1a-a3d8-0e3b5b1a0c12",
  "status": "stable",
  "description": "Detects PowerShell launched with an encoded command (-enc/-EncodedCommand). Commonly used to bypass command-line logging and execute obfuscated payloads.",
  "level": "high",
  "tags": ["attack.execution", "attack.t1059.001", "attack.defense_evasion", "attack.t1027.010"],
  "logsource": {"category": "process_creation", "product": "windows"},
  "detection": {
    "selection_enc": {
      "Image|endswith": ["\\powershell.exe", "\\pwsh.exe"],
      "CommandLine|contains|all": ["-e "]
    },
    "selection_encoded": {
      "Image|endswith": ["\\powershell.exe", "\\pwsh.exe"],
      "CommandLine|contains": "-EncodedCommand"
    },
    "selection_enc2": {
      "Image|endswith": ["\\powershell.exe", "\\pwsh.exe"],
      "CommandLine|contains": "-enc "
    },
    "condition": "1 of selection*"
  },
  "falsepositives": ["Legitimate automation scripts using encoded commands"]
}
