{
  "title": "Lateral Movement via WMI Remote Execution",
  "id": "d1e2f3a4-b5c6-4d7e-f8a9-b0c1d2e3f4a5",
  "status": "stable",
  "description": "Detects wmic.exe used to execute commands on a remote host — classic lateral movement technique.",
  "level": "high",
  "tags": ["attack.lateral_movement", "attack.execution", "attack.t1021.006", "attack.t1047"],
  "logsource": {"category": "process_creation", "product": "windows"},
  "detection": {
    "selection": {
      "Image|endswith": ["\\wmic.exe", "\\WMIC.exe"],
      "CommandLine|contains": ["/node:"]
    },
    "condition": "selection"
  },
  "falsepositives": ["Legitimate remote WMI administration", "Monitoring tools using WMI"]
}
